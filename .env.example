# Copy to .env and edit. docker-compose reads this automatically.

# --- Postgres ---
POSTGRES_USER=staffadmin
POSTGRES_PASSWORD=staffpass
POSTGRES_DB=staffmgmt

# --- Backend ---
# Generate a strong secret, e.g.:  openssl rand -hex 32
JWT_SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=720

# First-run Super Admin (change these, then log in and create real users)
SEED_ADMIN_USERNAME=superadmin
SEED_ADMIN_PASSWORD=ChangeMe123!
DEFAULT_TENANT_ID=1
